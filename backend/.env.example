# Copy this file to .env and fill in your values.

# --- Database ---
# Local development (SQLite — no setup needed):
DATABASE_URL=sqlite:///./academic_twin.db

# Production (PostgreSQL — replace with your Railway/Render URL):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- AI Advisor ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Security ---
# Generate a strong random string for production:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-change-in-production

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# --- Email (Gmail SMTP for password reset) ---
# Step 1: Enable 2-Step Verification on your Google account
# Step 2: Google Account → Security → App Passwords → Create → copy the 16-char password
SMTP_USER=youremail@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# URL of your deployed frontend (used in reset-password email links)
FRONTEND_URL=https://academic-digital-twin-simulator.vercel.app
