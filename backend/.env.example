# Copy this file to .env and fill in your values.

# --- Database ---
# Local development (SQLite — no setup needed):
DATABASE_URL=sqlite:///./academic_twin.db

# Production (PostgreSQL — replace with your Railway/Render URL):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- AI Advisor ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Security ---
# Generate a strong random string for production:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-change-in-production

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# --- Email (Resend — works on Railway, no SMTP port blocking) ---
# Sign up free at https://resend.com → API Keys → Create Key
# Free tier: 3,000 emails/month, 100/day
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# URL of your deployed frontend (used in reset-password email links)
FRONTEND_URL=https://academic-digital-twin-simulator.vercel.app
